# HissePro COMP Engine - Environment Configuration

# Application
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/hissepro_comp
# OR use individual settings:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_NAME=hissepro_comp

# Cache (Redis/Valkey)  
REDIS_URL=redis://localhost:6379/0
# OR use individual settings:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password
# REDIS_DB=0

# Scheduler
ENABLE_SCHEDULER=true

# Security
SECRET_KEY=your-secret-key-here

# AI Integration (Optional)
GEMINI_API_KEY=your-gemini-api-key
HONO_BASE_URL=http://localhost:8787

# CORS (Development)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8787","*"]

# Monitoring (Optional)
SENTRY_DSN=https://your-sentry-dsn
ENABLE_METRICS=true